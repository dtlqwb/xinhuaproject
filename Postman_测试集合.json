            "url": {
              "raw": "{{baseUrl}}/api/sales/today-count?salesId=1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sales", "today-count"],
              "query": [
                {
                  "key": "salesId",
                  "value": "1"
                }
              ]
            }
          }
        }
      ]
    },
    {
